/* =============================================================================
   Auto score updater for the EGEC World Cup Predictor.

   Repo path: scripts/update-scores.mjs

   Requires:
   - matches.json in repo root
   - FIREBASE_SERVICE_ACCOUNT secret
   - FOOTBALL_TOKEN secret, or temporary fallback token below
   ========================================================================== */

import fs from "fs";
import admin from "firebase-admin";

const SA = JSON.parse(process.env.FIREBASE_SERVICE_ACCOUNT || "{}");

// Uses GitHub secret first.
// If secret is broken/missing, uses your pasted token temporarily.
const TOKEN = (
  process.env.FOOTBALL_TOKEN ||
  "062dd9d5f4f04baab9ffac84d510befb"
).trim().replace(/\s+/g, "");

const COMP = process.env.COMPETITION || "WC";

if (!SA.project_id) {
  console.error("Missing or invalid FIREBASE_SERVICE_ACCOUNT secret");
  process.exit(1);
}

if (!TOKEN) {
  console.error("Missing FOOTBALL_TOKEN");
  process.exit(1);
}

admin.initializeApp({
  credential: admin.credential.cert(SA)
});

const db = admin.firestore();

const ALIAS = {
  iriran: "iran",
  iran: "iran",

  congodr: "drcongo",
  drcongo: "drcongo",
  congodemocraticrepublic: "drcongo",
  democraticrepublicofcongo: "drcongo",

  caboverde: "capeverde",
  capeverde: "capeverde",

  curacao: "curacao",
  curaçao: "curacao",

  turkiye: "turkey",
  turkey: "turkey",

  korearepublic: "southkorea",
  republicofkorea: "southkorea",
  southkorea: "southkorea",

  unitedstates: "usa",
  unitedstatesofamerica: "usa",
  usa: "usa",

  cotedivoire: "ivorycoast",
  ivorycoast: "ivorycoast",

  bosniaandherzegovina: "bosnia",
  bosnia: "bosnia"
};

function norm(value) {
  const clean = String(value || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z]/g, "");

  return ALIAS[clean] || clean;
}

async function main() {
  if (!fs.existsSync("matches.json")) {
    console.error("matches.json not found in repo root");
    process.exit(1);
  }

  const localData = JSON.parse(fs.readFileSync("matches.json", "utf8"));
  const ours = localData.matches || [];

  const res = await fetch(
    `https://api.football-data.org/v4/competitions/${COMP}/matches`,
    {
      headers: {
        "X-Auth-Token": TOKEN
      }
    }
  );

  if (!res.ok) {
    console.error("API error", res.status, await res.text());
    process.exit(1);
  }

  const data = await res.json();
  const api = data.matches || [];

  console.log(`API returned ${api.length} matches for ${COMP}`);

  const byPair = {};

  for (const am of api) {
    const home = norm(am.homeTeam?.name);
    const away = norm(am.awayTeam?.name);

    byPair[`${home}|${away}`] = am;
  }

  let writes = 0;
  let skipped = 0;

  for (const m of ours) {
    const key = `${norm(m.home)}|${norm(m.away)}`;
    const am = byPair[key];

    if (!am) {
      skipped++;
      console.log(`Skipped: ${m.home} vs ${m.away} - no API match`);
      continue;
    }

    let status = null;

    if (am.status === "FINISHED") {
      status = "finished";
    } else if (am.status === "IN_PLAY" || am.status === "PAUSED") {
      status = "live";
    } else {
      console.log(`Not started: ${m.home} vs ${m.away}`);
      continue;
    }

    const score = am.score?.fullTime || {};
    const homeScore = score.home;
    const awayScore = score.away;

    if (homeScore == null || awayScore == null) {
      console.log(`No score yet: ${m.home} vs ${m.away}`);
      continue;
    }

    await db.collection("results").doc(m.id).set(
      {
        homeScore,
        awayScore,
        status,
        updatedAt: admin.firestore.FieldValue.serverTimestamp()
      },
      { merge: true }
    );

    writes++;
    console.log(`Updated: ${m.home} ${homeScore}-${awayScore} ${m.away} [${status}]`);
  }

  console.log(`Updated ${writes} result(s).`);
  console.log(`Skipped ${skipped} unmatched match(es).`);
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
